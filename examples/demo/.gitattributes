# Mark buf-generated protobuf bindings as generated so GitHub collapses them
# in PR diffs by default. The files are still in the repo (so `git clone &&
# go build` works without the buf+protoc toolchain), but they don't drown
# real changes in PR review.
gen/go/**/*.pb.go      linguist-generated=true
gen/python/**/*_pb2.py linguist-generated=true

# openevents-generated Go bindings. These are emitted by the per-domain Go
# emitter (internal/codegen/golang) and re-run with `make gen` whenever the
# registry changes. Source of truth is the registry YAML, not these files.
services/api/eventmap/*/event_names.go linguist-generated=true
services/api/eventmap/*/context.go     linguist-generated=true
services/api/eventmap/*/*_request.go   linguist-generated=true

# Lockfile is hand-authored conceptually (the proto numbers are facts the
# project maintains forever) but mechanically produced by `openevents lock
# update`. Mark as generated so it doesn't dominate diffs.
registry/openevents.lock.yaml linguist-generated=true

# Python generated event-name constants and context dataclasses.
services/consumer/src/consumer/event_names/*.py linguist-generated=true
services/consumer/src/consumer/context/*.py     linguist-generated=true
